root = true

[*]
# # 以下四个选项，会被映射为Prettier的 useTabs, tabWidth, printWidth, endOfLine

# 缩进样式
indent_style = space
# 缩进大小
indent_size = 2
# 每行最大长度
max_line_length = 110
# 行尾类型
end_of_line = lf

# 以下选项不建议更改
# 字符集=utf-8
charset = utf-8
# 删除行尾空格
trim_trailing_whitespace = true
# 插入最后一行
insert_final_newline = true


[*.md]
max_line_length = off
trim_trailing_whitespace = false
